# ==========================
# Docker Compose (produção)
# ==========================

# Domínios públicos
VITE_APP_URL=https://app.ziradesk.com
VITE_API_URL=https://api.ziradesk.com
VITE_SOCKET_URL=https://api.ziradesk.com

# LGPD / Jurídico
PRIVACY_POLICY_URL=
TERMS_OF_SERVICE_URL=
COMPANY_LEGAL_NAME=
COMPANY_CNPJ=

# Banco (usado pelo serviço postgres e pelo DATABASE_URL da API)
POSTGRES_DB=ziradesk
POSTGRES_USER=ziradesk
POSTGRES_PASSWORD=troque-esta-senha-forte

# Conexões internas (sobrescreva apenas se necessário)
DATABASE_URL=postgresql://ziradesk:troque-esta-senha-forte@postgres:5432/ziradesk
REDIS_URL=redis://redis:6379

# ─── Cloudflare R2 (Backup) ──────────────────────────────────
# Configurado via rclone na VPS — não é usado pela aplicação diretamente
# Documentação: ops/backup.sh
# R2_ACCOUNT_ID=seu_account_id
# R2_ACCESS_KEY_ID=seu_access_key
# R2_SECRET_ACCESS_KEY=seu_secret_key
# R2_BUCKET=ziradesk-backups
