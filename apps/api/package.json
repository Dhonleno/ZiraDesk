{
  "name": "@ziradesk/api",
  "version": "0.8.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "dev:secondary": "tsx watch --env-file=.env --env-file=.env.secondary src/server.ts",
    "build": "pnpm --filter @ziradesk/shared build && prisma generate && tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "tsx --env-file=.env prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force",
    "migrate:indexes": "tsx --env-file=.env src/scripts/migrate-conversations-indexes.ts",
    "contacts:migrate-tags": "tsx --env-file=.env src/scripts/migrate-contact-tags.ts",
    "contacts:normalize-phones": "tsx --env-file=.env src/scripts/normalize-contact-phones.ts",
    "whatsapp:templates:resync": "tsx --env-file=.env src/scripts/resync-templates.ts",
    "whatsapp:webhook:simulate": "tsx --env-file=.env src/scripts/simulate-whatsapp-webhook.ts",
    "test": "node --env-file=.env.test ./node_modules/vitest/vitest.mjs run --config vitest.config.ts",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx --env-file=.env prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.14.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@ziradesk/shared": "workspace:*",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.2",
    "cheerio": "^1.2.0",
    "fastify": "^4.27.0",
    "fastify-raw-body": "^4.3.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.13.1",
    "mammoth": "^1.12.0",
    "nodemailer": "^8.0.7",
    "openai": "^6.37.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.6.0",
    "resend": "^6.12.2",
    "socket.io": "^4.7.5",
    "twilio": "^6.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^7.2.0",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.14.0",
    "supertest": "^7.2.2",
    "tsx": "^4.11.2",
    "typescript": "^5.4.5",
    "vitest": "^2.1.9"
  }
}
