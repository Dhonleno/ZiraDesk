# Database
DATABASE_URL=postgresql://ziradesk:ziradesk@localhost:5432/ziradesk?connection_limit=90&pool_timeout=10

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-jwt-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars

# App
PORT=3333
NODE_ENV=development
APP_URL=http://localhost:5173

# Encryption (AES-256 key, exactly 32 chars)
ENCRYPTION_KEY=change-me-encryption-key-32-chars

# WhatsApp (Meta Cloud API)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=
META_GRAPH_VERSION=v23.0

# Twilio Voice
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_TWIML_APP_SID=
TWILIO_API_KEY=
TWILIO_API_SECRET=
API_URL=
REFRESH_COOKIE_NAME=zd_refresh

# Resend (Inbound + confirmação por e-mail)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=

# Storage
STORAGE_PROVIDER=local         # local | r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=                 # ex: https://cdn.ziradesk.com.br

# Seed
# SEED_SUPER_ADMIN_EMAIL=admin@ziradesk.com
# SEED_SUPER_ADMIN_PASSWORD é OBRIGATÓRIA — o seed falha (throw) sem ela.
# Defina uma senha forte antes de rodar `pnpm --filter @ziradesk/api db:seed`.
SEED_SUPER_ADMIN_PASSWORD=
# SEED_DEMO_EMAIL=owner@demo.ziradesk.com

# LGPD / DPO
DPO_NAME=
DPO_EMAIL=
DPO_PHONE=
PRIVACY_POLICY_URL=
TERMS_OF_SERVICE_URL=
SUPER_ADMIN_EMAIL=     # recebe alertas de SLA LGPD estourado
